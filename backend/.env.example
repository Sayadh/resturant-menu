# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated allowed origins for CORS (public menu + admin)
CORS_ORIGINS=http://localhost:3000,https://affiliation-consideration-ended-postage.trycloudflare.com

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qr_menu_platform?schema=public"

# ── Auth (access + refresh) ───────────────────────────────────
JWT_ACCESS_SECRET="change-me-access"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Landing leads → Telegram (keep the real values ONLY in .env) ──
# Get chat id: message your bot, then open
#   https://api.telegram.org/bot<token>/getUpdates  → copy result[].message.chat.id
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
